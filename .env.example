# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# The pipeline uses exactly ONE controlled LLM call (the review stage).
# If no key is set, the pipeline still runs fully via a deterministic stub provider.
#
# Either variable name works (CLAUDE_API_KEY is checked first, then ANTHROPIC_API_KEY):
CLAUDE_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# EVAL_LLM_MODEL=claude-sonnet-5
# EVAL_LLM_PROVIDER=auto   # auto | anthropic | stub
